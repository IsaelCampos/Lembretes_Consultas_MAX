{
  "name": "whatsapp-lembrete",
  "version": "1.0.5",
  "description": "Lembretes automáticos de consultas via WhatsApp",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "date-fns": "^3.6.0",
    "electron-log": "^5.1.2",
    "electron-updater": "^6.1.7",
    "googleapis": "^144.0.0",
    "node-cron": "^3.0.3",
    "qrcode": "^1.5.3",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.23.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.seudominio.whatsapp-lembrete",
    "productName": "WhatsApp Lembrete",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "IsaelCampos",
      "repo": "Lembretes_Consultas_MAX",
      "private": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}